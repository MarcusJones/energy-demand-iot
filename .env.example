# =============================================================================
# GREEN TFP — ENVIRONMENT VARIABLES
# =============================================================================
#
# FILE NAMING CONVENTION
# ─────────────────────
#   .env          → local dev (points at your personal dev Supabase project)
#   .env.demo     → demo stage (used by: pnpm deploy:demo)
#   .env.prod     → production stage (used by: pnpm deploy)
#
# All three files are gitignored. Copy this file to each and fill in values.
#
# LOCAL DEV SETUP (Next.js)
# ─────────────────────────
# The dev server REQUIRES an explicit ENV argument:
#   ENV=demo pnpm dev       ← loads .env.demo
#   ENV=local pnpm dev      ← loads .env
#   ENV=prod pnpm dev       ← loads .env.prod (careful!)
#
# Running `pnpm dev` without ENV will fail with an error.
#
# =============================================================================


# =============================================================================
# 1. SUPABASE PROJECT URL
# =============================================================================
# The base URL for your Supabase project's API.
#
# WHERE TO FIND:
#   Dashboard → Settings → API → Project URL
#   (it's the first thing on the page)
#
# Listed twice because Next.js requires NEXT_PUBLIC_ prefix for browser access.
# BOTH values are identical — same URL, copy-paste it twice.

SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co


# =============================================================================
# 2. SUPABASE API KEYS (there are two — one public, one secret)
# =============================================================================
# WHERE TO FIND BOTH:
#   Dashboard → Settings → API → Project API Keys
#   You'll see two keys listed on the same page.
#
# PUBLISHABLE KEY (safe for browser, limited access):
#   The one labelled "anon" / "public" — starts with sb_publishable_
#
# SECRET KEY (full admin access, NEVER goes to browser):
#   The one labelled "service_role" — starts with sb_secret_
#   Click "Reveal" to see it.

NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# =============================================================================
# 3. DATABASE CONNECTION STRING (for migration & import scripts)
# =============================================================================
# A direct Postgres connection string. Used by scripts that run raw SQL
# (create-tables.ts, import-transactions.ts, seed scripts, etc.)
#
# WHERE TO FIND:
#   Dashboard → Settings → Database → Connection string
#   Select "URI" tab → copy the string
#   Replace [YOUR-PASSWORD] with the database password you set when creating
#   the Supabase project.
#
# NOTE: If you forgot the password, reset it at:
#   Dashboard → Settings → Database → Database password → Reset

DATABASE_URL=postgresql://postgres.xxxxxxxxxxxxxxxxxxxx:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres


# =============================================================================
# 4. SUPABASE ACCESS TOKEN (only for deploying edge functions)
# =============================================================================
# A personal account token — NOT a project key. Only needed if you run
# `pnpm db:deploy-functions` or `pnpm db:setup` (which deploys functions).
# If you deploy edge functions manually from the Dashboard, skip this.
#
# WHERE TO FIND:
#   Click your avatar (top-right) → Account → Access Tokens → Generate
#   Starts with sbp_

SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# =============================================================================
# 5. AWS CREDENTIALS (only for SST deployment — not needed for local dev)
# =============================================================================
# Required when running: pnpm deploy:demo / pnpm deploy
# Skip this section entirely if you only run `pnpm dev` locally.
#
# WHERE TO FIND:
#   1. AWS Console → IAM → Users → Create user
#   2. Attach policy: AdministratorAccess
#   3. Security credentials tab → Create access key → copy values below

AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=eu-central-1


# =============================================================================
# 6. CUSTOM DOMAIN (optional — only for SST deployment)
# =============================================================================
# Set both values to serve the site on a custom subdomain instead of the
# default CloudFront URL. Requires the Route 53 hosted zone to already exist.
#
# WHERE TO FIND ROUTE53_ZONE_ID:
#   aws route53 list-hosted-zones --query "HostedZones[?Name=='yourdomain.com.'].Id" --output text
#   Strip the /hostedzone/ prefix — use just the ID (e.g. Z0XXXXXXXXXX).

# CUSTOM_DOMAIN=green-tfp-demo.ic-ces.engineering
# ROUTE53_ZONE_ID=Z0XXXXXXXXXX


# =============================================================================
# 7. LANGDOCK API KEY (only for AI features — set in Supabase, not here)
# =============================================================================
# NOT used by the app directly. Set this as a secret in Supabase Edge Functions:
#   Dashboard → Edge Functions → Secrets → add LANGDOCK_API_KEY
#
# Included here only as a reminder when setting up a new Supabase project.
#
# LANGDOCK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
